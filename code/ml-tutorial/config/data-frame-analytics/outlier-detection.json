{
  "description": "离群点检测 - 发现 Nginx 日志中的异常请求模式",
  "source": {
    "index": ["nginx-logs-*"],
    "query": {
      "match_all": {}
    }
  },
  "dest": {
    "index": "nginx-outliers",
    "results_field": "ml"
  },
  "analysis": {
    "outlier_detection": {
      "compute_feature_influence": true,
      "outlier_fraction": 0.05,
      "standardization_enabled": true
    }
  },
  "analyzed_fields": {
    "includes": [
      "status",
      "body_bytes_sent",
      "request_time"
    ]
  },
  "model_memory_limit": "100mb",
  "max_num_threads": 1
}
